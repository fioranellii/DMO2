<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtDescricaoPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="O que você está pensando?"
            android:minLines="3"
            android:maxLines="5"/>

        <TextView
            android:id="@+id/txtCidadePost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Localizando..."
            android:visibility="gone"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnSelecionarFotoPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecionar foto"
            android:layout_marginTop="12dp"/>

        <ImageView
            android:id="@+id/imgNovoPost"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"/>

        <Button
            android:id="@+id/btnLocalizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usar minha localização" />

        <TextView
            android:id="@+id/txtCidadeNovoPost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sem localização" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>